# Copy to .env for local development. Do not commit .env.

# Model/API providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ELEVENLABS_API_KEY=

# App settings
FABLE_ENV=development
FABLE_DATABASE_URL=sqlite:///./runtime/fable_table_engine.sqlite3
FABLE_LOG_LEVEL=INFO

# Optional local server settings
FABLE_HOST=127.0.0.1
FABLE_PORT=8000
