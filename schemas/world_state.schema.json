{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fable-table-engine.local/schemas/world_state.schema.json",
  "title": "FABLE World State Skeleton",
  "type": "object",
  "required": [
    "entities",
    "scenes",
    "clocks",
    "fronts"
  ],
  "properties": {
    "entities": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/entity"
      }
    },
    "scenes": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "clocks": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "fronts": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "position": {
          "description": "Fiction-positional (D-002): no coordinates. Anchored to a zone and described in prose; proximity is qualitative and governed by position Truths.",
          "type": "object",
          "properties": {
            "zone": {
              "type": "string",
              "description": "Scene/zone graph node id."
            },
            "description": {
              "type": "string",
              "description": "Fictional position descriptor."
            },
            "proximity": {
              "type": "string",
              "description": "Optional coarse adjudication tag, e.g. adjacent / near / far."
            },
            "truths": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Ids of position Truths governing this entity."
            }
          },
          "additionalProperties": true
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resources": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
